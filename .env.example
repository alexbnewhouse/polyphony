# polyphony environment configuration
# Copy this to .env and edit as needed.

# Ollama server URL (default: local)
# POLYPHONY_OLLAMA_HOST=http://localhost:11434

# Directory where projects are stored (default: ~/.polyphony/projects/)
# POLYPHONY_PROJECTS_DIR=/path/to/my/projects

# Directory for prompt templates (default: ./prompts/ relative to package)
# POLYPHONY_PROMPTS_DIR=/path/to/custom/prompts
